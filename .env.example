# Environment Variables Template
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# ⚠️  NEVER commit .env.local to Git — it is already in .gitignore

# ── Hasura GraphQL Engine ─────────────────────────────────────────────────────
# URL of your running Hasura instance
NEXT_PUBLIC_HASURA_ENDPOINT=http://localhost:8080/v1/graphql

# Hasura admin secret — must match HASURA_GRAPHQL_ADMIN_SECRET in docker-compose.yml
HASURA_ADMIN_SECRET=myadminsecret

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Must be at least 32 characters long
# Must match HASURA_GRAPHQL_JWT_SECRET.key in docker-compose.yml
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# ── Demo Mode ─────────────────────────────────────────────────────────────────
# true  → Run with local mock data (no database or Docker needed)
# false → Use real PostgreSQL via Hasura (requires full setup)
NEXT_PUBLIC_DEMO_MODE=true
